<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GearShift.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="36,28" Spacing="20" MaxWidth="920" HorizontalAlignment="Stretch">
            <TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- 常规 -->
            <StackPanel Spacing="8">
                <TextBlock Text="常规" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <Grid Padding="16,12" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="1">
                                <TextBlock Text="开机自启动" />
                                <TextBlock Text="随 Windows 启动 GearShift" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch x:Name="AutoStartToggle" Grid.Column="1" OnContent="" OffContent=""
                                          Toggled="OnAutoStartToggled" />
                        </Grid>
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid Padding="16,12" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="1">
                                <TextBlock Text="启动时最小化到托盘" />
                                <TextBlock Text="不显示主窗口" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch x:Name="StartMinToggle" Grid.Column="1" OnContent="" OffContent=""
                                          Toggled="OnSettingChanged" />
                        </Grid>
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid Padding="16,12" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="1">
                                <TextBlock Text="默认场景" />
                                <TextBlock Text="启动时自动应用" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <ComboBox x:Name="DefaultSceneCombo" Grid.Column="1" MinWidth="160"
                                      SelectionChanged="OnDefaultSceneChanged" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 外观与通知 -->
            <StackPanel Spacing="8">
                <TextBlock Text="外观与通知" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <Grid Padding="16,12" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="主题" VerticalAlignment="Center" />
                            <ComboBox x:Name="ThemeCombo" Grid.Column="1" MinWidth="160"
                                      SelectionChanged="OnThemeChanged">
                                <ComboBoxItem Content="跟随系统" />
                                <ComboBoxItem Content="浅色" />
                                <ComboBoxItem Content="深色" />
                            </ComboBox>
                        </Grid>
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid Padding="16,12" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="1">
                                <TextBlock Text="切换后显示通知" />
                                <TextBlock Text="托盘弹出切换结果" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch x:Name="NotifyToggle" Grid.Column="1" OnContent="" OffContent=""
                                          Toggled="OnSettingChanged" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 权限与安全 -->
            <StackPanel Spacing="8">
                <TextBlock Text="权限与安全" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <Grid Padding="16,12" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="1">
                                <TextBlock Text="关键进程安全名单" />
                                <TextBlock Text="名单中的进程永不会被关闭" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="查看" Click="OnViewSafetyList" />
                        </Grid>
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid Padding="16,12" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="1">
                                <TextBlock Text="管理员权限" />
                                <TextBlock x:Name="ElevStatus" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <Button x:Name="ElevButton" Grid.Column="1" Content="以管理员身份重启"
                                    Click="OnRestartElevated" />
                        </Grid>
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid Padding="16,12" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="1">
                                <TextBlock Text="导入插件时确认脚本" />
                                <TextBlock Text="运行前展示脚本内容" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch x:Name="ConfirmPluginToggle" Grid.Column="1" OnContent="" OffContent=""
                                          Toggled="OnSettingChanged" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 关于 -->
            <StackPanel Spacing="8">
                <TextBlock Text="关于" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Border CornerRadius="8" Padding="16,12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="1">
                        <TextBlock Text="GearShift" />
                        <TextBlock Text="版本 0.1.0 · 声明式场景切换工具" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
