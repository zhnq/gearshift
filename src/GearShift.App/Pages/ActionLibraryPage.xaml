<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GearShift.App.Pages.ActionLibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:GearShift.App.Services">

    <Grid Padding="36,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="动作库" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="管理可复用的动作插件，场景里直接引用"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                    Style="{StaticResource AccentButtonStyle}" Click="OnImport">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE896;" FontSize="14" />
                    <TextBlock Text="导入插件" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Action list -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="ActionsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="services:ActionDescriptor">
                        <Border CornerRadius="8" Padding="16,14" Margin="0,0,0,10"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Width="40" Height="40" CornerRadius="10"
                                        Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                    <TextBlock Text="{x:Bind Icon}" FontSize="20"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind Description}" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <ItemsControl ItemsSource="{x:Bind Chips}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Border CornerRadius="4" Padding="7,2"
                                                        Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                                    <TextBlock Text="{x:Bind}" FontSize="12"
                                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                                              OnContent="" OffContent=""
                                              IsOn="{x:Bind Enabled}"
                                              IsEnabled="{x:Bind CanToggle}"
                                              Toggled="OnActionToggled" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
